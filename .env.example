# ============================================================
# CETIEM — Variables de entorno
#
# Con Docker Compose (recomendado):
#   Solo necesitas llenar las claves de NVIDIA.
#   El resto lo maneja docker-compose automáticamente.
#
#   1. cp .env.example .env
#   2. Edita .env → agrega tus NVIDIA_API_KEY y NVIDIA_QA_API_KEY
#   3. docker compose up --build
#
# Sin Docker (desarrollo manual):
#   Descomenta y rellena TODAS las variables.
# ============================================================

# ── NVIDIA NIM — REQUERIDO ────────────────────────────────────
# Crea tu cuenta en https://build.nvidia.com (plan gratuito disponible)
NVIDIA_API_KEY=nvapi-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NVIDIA_QA_API_KEY=nvapi-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── NVIDIA — Modelos (opcionales, ya tienen valores por defecto) ──
# NVIDIA_CHAT_MODEL=meta/llama-3.1-70b-instruct
# NVIDIA_EMBEDDING_MODEL=llama-3_2-nemoretriever-300m-embed-v1
# NVIDIA_QA_MODEL=z-ai/glm4.7

# ── Auth (opcional con Docker — se genera automáticamente) ────
# Si no se define, docker-compose usa un valor de desarrollo seguro.
# En PRODUCCIÓN, genera claves propias: openssl rand -base64 32
# NEXTAUTH_SECRET=
# AUTH_SECRET=

# ─────────────────────────────────────────────────────────────
# Las variables de abajo son gestionadas por docker-compose.
# Solo descoméntalas si corres la app SIN Docker.
# ─────────────────────────────────────────────────────────────

# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000
# DATABASE_URL="postgresql://postgres:cetiem@localhost:5432/cetiem_db?schema=certificacion_ia"
# LOCAL_STORAGE_PATH=./uploads
# REDIS_HOST=localhost
# REDIS_PORT=6379
# FALKORDB_HOST=localhost
# FALKORDB_PORT=6380
# PAGEINDEX_LOCAL_MODE=true
# COGNEE_MODE=falkordb
# COGNEE_LLM_PROVIDER=nvidia
# COGNEE_EMBEDDING_PROVIDER=nvidia
# MAX_CHUNKS_TO_PROCESS=500
# MAX_BATCHES=100
