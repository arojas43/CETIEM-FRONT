# =========================================
# SISTEMA DE CERTIFICACIÓN EMPRESARIAL CON IA
# Archivo de Ejemplo de Variables de Entorno
# =========================================
# Copia este archivo a .env y reemplaza los valores
# cp .env.example .env

# =========================================
# NEXT.JS
# =========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =========================================
# DATABASE (PostgreSQL)
# =========================================
# Formato: postgresql://usuario:password@host:puerto/base_datos?schema=esquema
DATABASE_URL="postgresql://postgres:password@localhost:5432/cipre_db?schema=certificacion_ia"

# =========================================
# ALMACENAMIENTO LOCAL (Desarrollo)
# =========================================
# Ruta absoluta donde se guardarán los PDFs subidos
LOCAL_STORAGE_PATH=/ruta/completa/a/uploads

# =========================================
# NEXTAUTH (Autenticación)
# =========================================
NEXTAUTH_URL=http://localhost:3000
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=desarrollo-local-secret-key-12345

# =========================================
# NVIDIA NIM (Para procesamiento - PageIndex/Cognee)
# =========================================
# Obtener API Key en: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-tu-api-key-aqui
NVIDIA_EMBEDDING_MODEL=llama-3_2-nemoretriever-300m-embed-v1
NVIDIA_CHAT_MODEL=meta/llama-3.1-70b-instruct

# =========================================
# NVIDIA QWEN (Para Q&A - Mejor razonamiento)
# =========================================
# API Key separada para Qwen 3.5 122B
NVIDIA_QA_API_KEY=nvapi-tu-api-key-aqui

# =========================================
# REDIS (Para colas BullMQ)
# =========================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD= (dejar vacío para desarrollo local)

# =========================================
# PAGEINDEX
# =========================================
# true = Usar implementación local (recomendado)
# false = Usar API de PageIndex
PAGEINDEX_LOCAL_MODE=true
# PAGEINDEX_API_KEY= (solo si usas API externa)

# =========================================
# COGNEE + FALKORDB (Grafo de conocimiento)
# =========================================
COGNEE_MODE=falkordb
COGNEE_LLM_PROVIDER=nvidia
COGNEE_EMBEDDING_PROVIDER=nvidia
FALKORDB_HOST=localhost
FALKORDB_PORT=6380

# =========================================
# CONFIGURACIÓN DE PROCESAMIENTO
# =========================================

# Límite máximo de chunks a procesar por documento
# Valores recomendados:
#   - Documentos pequeños (<50 págs): 50
#   - Documentos medianos (50-500 págs): 200
#   - Documentos grandes (>500 págs): 500
#   - Documentos muy grandes (Biblia): 1000
MAX_CHUNKS_TO_PROCESS=500

# Límite máximo de lotes para documentos grandes
# Cada lote procesa 10 chunks en paralelo
# 100 lotes = 1000 chunks máximo
MAX_BATCHES=100

# Límite de contenido por índice de PageIndex (caracteres)
# Aumentar para más contexto en Q&A
MAX_CONTENT_PER_INDEX=5000

# =========================================
# CREDENCIALES POR DEFECTO (Desarrollo)
# =========================================
# Email: admin@local.dev
# Password: admin123
# ¡CAMBIAR EN PRODUCCIÓN!
