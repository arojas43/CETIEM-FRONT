# ============================================================
# CETIEM — Variables de entorno
# Copia este archivo como .env y rellena cada valor:
#   cp .env.example .env
# ============================================================

# ── App ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Base de datos (PostgreSQL) ───────────────────────────────
# Con docker-compose: ya configurado con estos valores
DATABASE_URL="postgresql://postgres:cetiem@localhost:5432/cetiem_db?schema=certificacion_ia"

# ── NextAuth ─────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
# Genera tu propia clave con: openssl rand -base64 32
NEXTAUTH_SECRET=REEMPLAZA_CON_CLAVE_ALEATORIA
AUTH_SECRET=REEMPLAZA_CON_CLAVE_ALEATORIA

# ── Almacenamiento de archivos ───────────────────────────────
LOCAL_STORAGE_PATH=./uploads

# ── NVIDIA NIM — LLM y Embeddings ───────────────────────────
# Crea tu cuenta y obtén una API key en: https://build.nvidia.com
# Plan gratuito incluye créditos suficientes para desarrollo
NVIDIA_API_KEY=nvapi-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NVIDIA_EMBEDDING_MODEL=llama-3_2-nemoretriever-300m-embed-v1
NVIDIA_CHAT_MODEL=meta/llama-3.1-70b-instruct

# ── NVIDIA NIM — Q&A sobre documentos ───────────────────────
# Puede ser la misma key que NVIDIA_API_KEY
NVIDIA_QA_API_KEY=nvapi-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Modelo para Q&A (default: z-ai/glm4.7 con thinking activado)
NVIDIA_QA_MODEL=z-ai/glm4.7

# ── Redis (BullMQ) ───────────────────────────────────────────
# Con docker-compose ya corre en localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# ── PageIndex ────────────────────────────────────────────────
PAGEINDEX_LOCAL_MODE=true

# ── Cognee + FalkorDB ────────────────────────────────────────
# Con docker-compose FalkorDB corre en localhost:6380
COGNEE_MODE=falkordb
COGNEE_LLM_PROVIDER=nvidia
COGNEE_EMBEDDING_PROVIDER=nvidia
FALKORDB_HOST=localhost
FALKORDB_PORT=6380

# ── Límites de procesamiento ─────────────────────────────────
MAX_CHUNKS_TO_PROCESS=500
MAX_BATCHES=100

# ── Google Cloud Storage (solo producción — omitir en dev) ───
# GOOGLE_CLOUD_PROJECT_ID=mi-proyecto-gcp
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json
# GOOGLE_CLOUD_STORAGE_BUCKET=cetiem-documents
