# ============================================================
# Variables para despliegue Cloud Run (frontend proxy)
# Copiar a .env.cloudrun y rellenar los valores reales
# ============================================================

# URL pública de este servicio Cloud Run (se sabe después del primer deploy)
NEXT_PUBLIC_APP_URL=https://certificacion-ia-HASH-uc.a.run.app
NEXTAUTH_URL=https://certificacion-ia-HASH-uc.a.run.app

# Cloudflare Tunnel que expone el backend local
# Obtener corriendo: cloudflared tunnel --url http://localhost:3001
BACKEND_URL=https://XXXX.trycloudflare.com

# Auth — MISMOS valores que en el backend local (.env)
NEXTAUTH_SECRET=desarrollo-local-secret-key-12345
AUTH_SECRET=desarrollo-local-secret-key-12345

# ── NO incluir estos en Cloud Run ────────────────────────────
# DATABASE_URL        → solo el backend local lo necesita
# REDIS_HOST/PORT     → solo el backend local lo necesita
# OPENKB_SERVICE_URL  → solo el backend local lo necesita
# NVIDIA_API_KEY      → solo el backend local lo necesita
# CEREBRAS_API_KEY    → solo el backend local lo necesita
