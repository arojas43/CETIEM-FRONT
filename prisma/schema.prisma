generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  COMPANY
  ASSESSOR
  ADMIN
}

enum TrackSectorial {
  A  // Industria
  B  // Construcción
  C  // Tecnología / Servicios
}

enum SprintLevel {
  STARTUP   // Sprint 1
  PEQUENA   // Sprint 2
  MEDIANA   // Sprint 3
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  password      String?
  role          UserRole  @default(COMPANY)
  // Company extra fields
  companyName   String?
  rfc           String?
  industry      String?
  phone         String?
  // ESG fields
  track         TrackSectorial?
  sprintLevel   SprintLevel @default(STARTUP)
  assessorId    String?          // Assessor assigned to this company
  assessor      User?            @relation("AssessorCompanies", fields: [assessorId], references: [id])
  companies     User[]           @relation("AssessorCompanies")

  accounts               Account[]
  sessions               Session[]
  documents              Document[]
  auditLogs              AuditLog[]
  capaTickets            CapaTicket[]
  companyCertifications  CompanyCertification[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Document {
  id            String             @id @default(cuid())
  name          String
  description   String?
  mimeType      String
  size          Int
  storageUrl    String
  status        DocumentStatus     @default(PENDING)
  domain        DocumentDomain     @default(INDUSTRIA)
  sha256        String?            // Hash SHA-256 del archivo
  // Catálogo de tipo de documento
  tipoDocumento String?            // ID del catálogo, e.g. "ACTA_CONSTITUTIVA"
  categoriaDoc  CategoriaDocumento @default(OTRO)
  userId        String
  user          User               @relation(fields: [userId], references: [id])
  certifications Certification[]
  pageIndices   PageIndex[]
  capaTickets   CapaTicket[]

  processingProgress Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DocumentStatus {
  PENDING
  PROCESSING
  INDEXED
  ANALYZED
  FAILED
}

enum DocumentDomain {
  INDUSTRIA
  CONSTRUCCION
  TECNOLOGIA
}

enum CategoriaDocumento {
  GOBERNANZA
  FINANCIERO
  AMBIENTAL
  SOCIAL
  LEGAL
  OPERACIONES
  OTRO
}

model PageIndex {
  id         String  @id @default(cuid())
  documentId String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  level      Int
  title      String
  content    String?  @db.Text
  page       Int?
  metadata   Json?
  parent     PageIndex? @relation("PageIndexHierarchy", fields: [parentId], references: [id])
  children   PageIndex[] @relation("PageIndexHierarchy")
  parentId   String?
  createdAt  DateTime @default(now())
}

model Certification {
  id             String   @id @default(cuid())
  name           String
  type           CertificationType
  status         CertificationStatus @default(DRAFT)
  requirements   Json     // { verdict, notes, assessorId, assessorEmail, assessedAt, vlap, confidenceScore, aiRecommendation }
  documentId     String
  document       Document @relation(fields: [documentId], references: [id])
  findings       Finding[]
  // ESG Certificate fields
  esgScore       Float?
  sha256Hash     String?  // Hash SHA-256 del certificado generado
  publicToken    String?  @unique  // UUID para verificación pública
  revokedAt      DateTime?
  revokedBy      String?
  revokeReason   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum CertificationType {
  ISO_9001
  ISO_14001
  ISO_45001
  FINANCIAL
  LEGAL
  CUSTOM
  ESG
}

enum CertificationStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  REJECTED
  REVOKED
  CAPA_OPEN
}

model Finding {
  id              String   @id @default(cuid())
  certificationId String
  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)
  type            FindingType
  severity        Severity
  title           String
  description     String   @db.Text
  evidence        String?  @db.Text
  recommendation  String?  @db.Text
  status          FindingStatus @default(OPEN)
  capaTicket      CapaTicket?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

enum FindingType {
  COMPLIANCE
  NON_COMPLIANCE
  OBSERVATION
  RECOMMENDATION
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum FindingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model CapaTicket {
  id                     String                @id @default(cuid())
  documentId             String
  document               Document              @relation(fields: [documentId], references: [id])
  findingId              String?               @unique
  finding                Finding?              @relation(fields: [findingId], references: [id])
  userId                 String
  user                   User                  @relation(fields: [userId], references: [id])
  /// Certificación de empresa a la que pertenece este ticket (cuando aplica)
  companyCertificationId String?
  companyCertification   CompanyCertification? @relation(fields: [companyCertificationId], references: [id])
  title                  String
  description            String                @db.Text
  dueDate                DateTime
  status                 CapaStatus            @default(OPEN)
  resolution             String?               @db.Text
  closedAt               DateTime?
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
}

enum CapaStatus {
  OPEN
  IN_PROGRESS
  CLOSED
  OVERDUE
}

/**
 * CompanyCertification — Dictamen ESG emitido por empresa completa.
 * Un solo certificado por empresa que cubre la totalidad de sus documentos analizados.
 * Los hallazgos y el V.L.A.P. se almacenan en el campo `requirements` (JSON).
 */
model CompanyCertification {
  id           String              @id @default(cuid())
  companyId    String
  company      User                @relation(fields: [companyId], references: [id])
  status       CertificationStatus @default(DRAFT)
  /// Contiene: { verdict, notes, assessorId, assessorEmail, assessedAt,
  ///             vlap, confidenceScore, findings[], documentIds[] }
  requirements Json
  esgScore     Float?
  sha256Hash   String?
  publicToken  String?             @unique
  revokedAt    DateTime?
  revokedBy    String?
  revokeReason String?
  capaTickets  CapaTicket[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String   // e.g. DOCUMENT_UPLOADED, CERT_ISSUED, CERT_REVOKED, CAPA_CREATED
  entityType  String   // Document, Certification, User, etc.
  entityId    String
  payload     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
}
